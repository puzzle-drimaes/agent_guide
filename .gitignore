# Editor and IDE local settings
.vscode/

# Per-tool / personal agent config (deployed adapter output or local settings;
# regenerable from canonical .agents/ — not shared source)
.claude/
.codex/
.gemini/
.cursor/

# Bundle build artifacts (regenerable via `npm run bundle`)
/release/

# Distribution test outputs (local manager-run logs; scripts are tracked)
tests/results/*
!tests/results/.gitignore

# Local shared Markdown candidates. Keep quarantine folders but do not commit
# downloaded/shared candidate content before review and promotion.
AI-Knowhow/**
!AI-Knowhow/**/
!AI-Knowhow/**/.gitkeep
