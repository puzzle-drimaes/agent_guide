{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.internal/agent-deploy/schemas/asset-pack.schema.json",
  "title": "Agent Deploy Asset Pack",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "id",
    "title",
    "version",
    "owner",
    "stability",
    "reviewStatus",
    "packType"
  ],
  "properties": {
    "schemaVersion": {
      "const": "agentdeploy.assetPack.v1"
    },
    "id": {
      "type": "string",
      "minLength": 3,
      "pattern": "^[a-z0-9][a-z0-9-]*[a-z0-9]$"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(?:[-+][0-9A-Za-z.-]+)?$"
    },
    "owner": {
      "type": "string",
      "minLength": 1
    },
    "stability": {
      "type": "string",
      "enum": ["draft", "beta", "stable", "deprecated"]
    },
    "reviewStatus": {
      "type": "string",
      "enum": ["candidate", "reviewing", "approved", "deprecated"]
    },
    "packType": {
      "type": "string",
      "enum": ["shared-approved", "project-local", "candidate"]
    },
    "source": {
      "type": "string",
      "minLength": 1
    },
    "license": {
      "type": "string",
      "minLength": 1
    },
    "defaultProfileExtensions": {
      "type": "object",
      "additionalProperties": {
        "type": "array",
        "minItems": 1,
        "items": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "notes": {
      "type": "string"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "packType": {
            "const": "candidate"
          }
        }
      },
      "then": {
        "properties": {
          "reviewStatus": {
            "enum": ["candidate", "reviewing"]
          }
        }
      }
    },
    {
      "if": {
        "not": {
          "properties": {
            "packType": {
              "const": "shared-approved"
            }
          }
        }
      },
      "then": {
        "not": {
          "required": ["defaultProfileExtensions"]
        }
      }
    },
    {
      "if": {
        "properties": {
          "packType": {
            "const": "shared-approved"
          }
        }
      },
      "then": {
        "properties": {
          "reviewStatus": {
            "const": "approved"
          }
        }
      }
    }
  ]
}
