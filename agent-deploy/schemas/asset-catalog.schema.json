{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "agent-deploy asset catalog draft",
  "description": "Draft schema for discovering and selecting Markdown assets by role/profile/module.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "generatedAt", "assets"],
  "properties": {
    "schemaVersion": {
      "const": "agentdeploy.assetCatalog.v1"
    },
    "generatedAt": {
      "type": ["string", "null"]
    },
    "assets": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "assetType",
          "title",
          "path",
          "moduleIds",
          "profiles",
          "audience",
          "stability",
          "owner",
          "reviewStatus"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9-]*$"
          },
          "assetType": {
            "enum": ["rule", "skill", "prompt", "template", "knowhow", "agent", "command"]
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string"
          },
          "path": {
            "type": "string",
            "minLength": 1
          },
          "moduleIds": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "profiles": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "audience": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "stability": {
            "enum": ["draft", "beta", "stable", "deprecated"]
          },
          "owner": {
            "type": "string",
            "minLength": 1
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "reviewStatus": {
            "enum": ["candidate", "reviewing", "approved", "deprecated", "rejected"]
          },
          "targets": {
            "type": "array",
            "items": {
              "enum": ["codex", "claude", "gemini", "cursor"]
            }
          },
          "skipReason": {
            "type": "string"
          }
        }
      }
    }
  }
}
